# Application
APP_NAME=Qi AI Studio
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=10011

# Database
DATABASE_URL=sqlite+aiosqlite:///./myai_studio.db

# Celery (可选，Phase 6 启用)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Security
SECRET_KEY=your-secret-key-here-change-in-production
API_KEY_ENCRYPTION_KEY=your-32-byte-encryption-key-here

# CORS
CORS_ORIGINS=http://localhost:11010,http://localhost:3000,http://localhost:5173,http://127.0.0.1:11010

# File Storage
UPLOAD_DIR=./storage/uploads
MAX_UPLOAD_SIZE=524288000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================================
# LLM Provider API Keys
# ============================================================
# 官方直连
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
QWEN_API_KEY=sk-your-qwen-api-key
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
GEMINI_API_KEY=your-gemini-api-key

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key

# Travel Agent external tools (optional)
AMAP_API_KEY=your_amap_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
JUHE_TRAIN_API_KEY=your_juhe_train_api_key_here
JUHE_FLIGHT_API_KEY=your_juhe_flight_api_key_here
HTTP_TIMEOUT_SECONDS=10
TAVILY_MAX_RESULTS=5

# Fitness Agent (optional)
USDA_FDC_API_KEY=your_usda_fdc_api_key_here
FITNESS_DEFAULT_TIMEZONE=Asia/Shanghai
FITNESS_DEFAULT_CALORIE_GOAL=1800

# Spider Agent (DeepAgents, Docker named volume sandbox)
SPIDER_CONTAINER_MOUNT_PATH=/workspace
# Default slim is fine for static HTTP pages.
# For JS-render escalation use e.g. mcr.microsoft.com/playwright/python:v1.61.0-jammy
SPIDER_DOCKER_IMAGE=python:3.11-slim
# Playwright path works more reliably at >=2g
SPIDER_DOCKER_MEMORY_LIMIT=1g
# Chromium in Docker; raise to 1gb+ to avoid page.content crashes on heavy SPAs
SPIDER_DOCKER_SHM_SIZE=1gb
SPIDER_DOCKER_CPU_QUOTA=100000

# Interview Navigator — RAG question bank (Ollama embeddings)
INTERVIEW_EMBEDDING_BASE_URL=http://localhost:11434
INTERVIEW_EMBEDDING_MODEL=nomic-embed-text
INTERVIEW_EMBEDDING_TIMEOUT=60.0
INTERVIEW_RAG_TOP_K=5
INTERVIEW_RAG_MIN_SCORE=0.35
# Hybrid: vector + BM25 + RRF
INTERVIEW_RAG_HYBRID=true
# lexical | none （默认 lexical；题库很大再考虑 neural CrossEncoder）
INTERVIEW_RERANK_MODE=lexical
# Embedding 熔断：连续失败次数 / 恢复秒数
INTERVIEW_EMBEDDING_BREAKER_FAILURES=3
INTERVIEW_EMBEDDING_BREAKER_RECOVERY=30
# 可选 LLM Route Reflection（默认关，避免泄漏标准答案）
INTERVIEW_ROUTE_REFLECTION_LLM=false
# Interview Resume Craft（默认 template，无需网络）
INTERVIEW_RESUME_CRAFT_PROVIDER=template
INTERVIEW_RESUME_CRAFT_MODEL=template
INTERVIEW_RESUME_CRAFT_BASE_URL=
INTERVIEW_RESUME_CRAFT_API_KEY=
