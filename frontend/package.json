  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "env -u ELECTRON_RUN_AS_NODE ELECTRON=1 vite",
    "build": "vite build",
    "build:desktop": "ELECTRON=1 VITE_API_BASE_URL=http://43.143.251.51:8081/api/v1 vite build",
    "pack:desktop": "npm run build:desktop && electron-builder --dir",
    "dist:desktop": "npm run build:desktop && electron-builder"
  },
  "build": {
    "appId": "com.qi.aistudio",
    "productName": "Qi AI Studio",
    "directories": {
      "output": "release"
    },
    "icon": "electron/icon.png",
    "files": [
      "build/**/*",
      "dist-electron/**/*",
      "electron/icon.png"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}