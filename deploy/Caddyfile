# DOMAIN 示例: ai.example.com
# 仅 HTTP（无域名）时可设为 :80，并注释掉自动 HTTPS 相关说明

{$DOMAIN} {
	encode gzip

	handle /api/* {
		reverse_proxy backend:10011 {
			flush_interval -1
		}
	}

	handle /docs* {
		reverse_proxy backend:10011
	}

	handle /redoc* {
		reverse_proxy backend:10011
	}

	handle /openapi.json {
		reverse_proxy backend:10011
	}

	handle /health {
		reverse_proxy backend:10011
	}

	handle {
		reverse_proxy frontend:80
	}
}
