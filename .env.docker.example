# 复制为项目根目录 .env 后修改:
#   cp .env.docker.example .env

# ========== 必填 ==========
# 你的域名（需已解析到云服务器公网 IP）
DOMAIN=ai.example.com

# JWT 签名密钥（随机长字符串）
SECRET_KEY=change-me-to-a-long-random-string

# API Key 加密密钥（Fernet，可用 backend/generate_encryption_key.py 生成）
API_KEY_ENCRYPTION_KEY=

# 与访问地址一致，含 https
CORS_ORIGINS=https://ai.example.com

# ========== 可选：Provider 默认 Key（也可在 UI 里 BYOK）==========
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
QWEN_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ========== 可选：旅行 Agent 外部工具 ==========
# 若此处为空，scripts/docker-deploy.sh 会尝试从 backend/.env 自动合并
AMAP_API_KEY=
TAVILY_API_KEY=
JUHE_TRAIN_API_KEY=
JUHE_FLIGHT_API_KEY=
HTTP_TIMEOUT_SECONDS=10
TAVILY_MAX_RESULTS=5

# ========== 日志 ==========
LOG_LEVEL=INFO
LOG_FORMAT=json
